rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isMapPayload() {
      return request.resource.data is map;
    }

    function validUserProfile(userId) {
      return !('uid' in request.resource.data) || request.resource.data.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && validUserProfile(userId);
      allow delete: if isOwner(userId);

      match /studyLogs/{documentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isMapPayload();
        allow delete: if isOwner(userId);
      }

      match /studyEvents/{documentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isMapPayload();
        allow delete: if isOwner(userId);
      }

      match /goals/{documentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isMapPayload();
        allow delete: if isOwner(userId);
      }

      match /certificates/{documentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isMapPayload();
        allow delete: if isOwner(userId);
      }

      match /settings/{documentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isMapPayload();
        allow delete: if isOwner(userId);
      }

      match /localConfig/{documentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isMapPayload();
        allow delete: if isOwner(userId);
      }

      match /syncMeta/{documentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isMapPayload();
        allow delete: if isOwner(userId);
      }

      match /records/{documentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isMapPayload();
        allow delete: if isOwner(userId);
      }

      match /achievements/{documentId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isMapPayload();
        allow delete: if isOwner(userId);
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
}
